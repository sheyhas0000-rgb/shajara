rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidFamilyMember(data) {
      return data.name is string && data.name.size() > 0 &&
             data.role is string &&
             data.status in ['alive', 'deceased'] &&
             data.type in ['adult', 'child'] &&
             data.generation is number &&
             (data.parentId == null || data.parentId is string);
    }

    match /familyMembers/{memberId} {
      allow read: if true; 
      allow create, update: if isSignedIn() && isValidFamilyMember(request.resource.data);
      allow delete: if isSignedIn();
    }
  }
}
